# SuppleSphere Environment Variables

# PocketBase
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# Site URL (used for sitemap, OG images, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://supplesphere.com

# PocketBase Admin (for server-side operations)
POCKETBASE_ADMIN_EMAIL=admin@supplesphere.com
POCKETBASE_ADMIN_PASSWORD=your-secure-password-here
